{
  "compilerOptions": {
    "jsx": "react",
    "esModuleInterop": true,
    "baseUrl": "src",
    "inlineSourceMap": true,
    "inlineSources": true,
    "isolatedModules": true,
    "module": "ESNext",
    "target": "es2018",
    "allowJs": true,
    "alwaysStrict": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["dom", "es5", "scripthost", "es2020", "es2022"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
  ],
  "exclude": [],
}
